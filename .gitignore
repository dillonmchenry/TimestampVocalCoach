stars_student/
*.ckpt
# RMVPE weights (~180 MB); download separately (HF verstar/STARS or setup script)
rmvpe/
# PyTorch weights — ignore by default; allow student checkpoint below
*.pt
!data/student_v6/
!data/student_v6/**

# third_party/stars: vendored STARS source (RMVPE import). Clone without a nested
# .git/ (see third_party/README.md) or only the parent repo will see an empty folder.
# Runtime weights/symlinks under checkpoints/ stay out of git.
third_party/stars/checkpoints/
third_party/stars/infer_out/

